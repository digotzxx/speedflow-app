{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/terms.html/",
      "destination": "/terms.html"
    },
    {
      "source": "/privacy.html/",
      "destination": "/privacy.html"
    },
    {
      "source": "/auth/callback/tiktok",
      "destination": "/index.html"
    },
    {
      "source": "/((?!terms.html|privacy.html|tiktok).*)",
      "destination": "/index.html"
    }
  ]
}
